# Server
PORT=8080

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_JUDGE_MODEL=llama3
OLLAMA_PROXY_MODEL=llama3

# Entropy thresholds
ENTROPY_HIGH_THRESHOLD=6.5
ENTROPY_SUSPICIOUS_THRESHOLD=5.5

# Token budget per user per hour
TOKEN_BUDGET_PER_HOUR=50000

# Penalty TTL in minutes
PENALTY_TTL_MINUTES=60

# Rate limit: requests per minute per user fingerprint
RATE_LIMIT_RPM=60

# Optional: protect the proxy with a Bearer token
# AEGIS_API_KEY=your-secret-key
